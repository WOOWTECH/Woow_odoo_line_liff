<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/res_config_settings_views.xml -->
<!-- 設定頁：POS 風格 config 選擇器 + related 欄位 -->
<odoo>

    <record id="res_config_settings_view_form_line_bridge" model="ir.ui.view">
        <field name="name">res.config.settings.form.line.bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="LINE Bridge" string="LINE Bridge"
                     name="woow_line_bridge" data-key="woow_line_bridge"
                     logo="/woow_line_bridge/static/description/line_icon.png"
                     groups="woow_line_base.group_line_manager">

                    <!-- POS 風格：設定檔選擇器 -->
                    <block title="LINE 設定檔" name="line_config_selector">
                        <setting string="LINE 設定檔" help="選擇要檢視/編輯的 LINE 設定檔，或新增一個">
                            <div class="content-group">
                                <div class="row mt16">
                                    <field name="line_liff_config_id" class="col-lg-4"/>
                                    <button type="action"
                                            name="%(woow_line_bridge.action_line_liff_config)d"
                                            string="+新增設定檔" class="btn-link col-lg-3"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <div invisible="not line_liff_config_id">

                        <block title="API 憑證" name="line_api_credentials">
                            <setting string="Messaging API">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="cfg_messaging_channel_id" string="Channel ID"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_messaging_channel_id" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_messaging_channel_secret" string="Channel Secret"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_messaging_channel_secret" class="col-lg-6"
                                               password="True"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_messaging_access_token" string="Access Token"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_messaging_access_token" class="col-lg-6"
                                               password="True"/>
                                    </div>
                                </div>
                            </setting>
                            <setting string="LINE Login">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="cfg_login_channel_id" string="Login Channel ID"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_login_channel_id" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_login_channel_secret" string="Login Secret"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_login_channel_secret" class="col-lg-6"
                                               password="True"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="LIFF 設定" name="line_liff_settings">
                            <setting string="LIFF App IDs">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="cfg_liff_id_member" string="會員中心"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_liff_id_member" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_liff_id_news" string="最新消息"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_liff_id_news" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_liff_id_locations" string="店家位置"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_liff_id_locations" class="col-lg-6"/>
                                    </div>
                                </div>
                            </setting>
                            <setting string="端點 URL" help="貼到 LINE Developer Console">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="cfg_webhook_url" string="Webhook"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_webhook_url" class="col-lg-6"
                                               widget="CopyClipboardChar" readonly="1"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="店家資訊" name="line_shop_settings">
                            <setting string="基本資訊">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="cfg_shop_name" string="店家名稱"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_shop_name" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_shop_phone" string="電話"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_shop_phone" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_shop_address" string="地址"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_shop_address" class="col-lg-6"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="cfg_shop_opening_hours" string="營業時間"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_shop_opening_hours" class="col-lg-6"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <block title="行為設定" name="line_behavior_settings">
                            <setting string="自動推播">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <field name="cfg_auto_line_notify" class="col-lg-3"/>
                                        <span class="col-lg-6 text-muted">追蹤欄位變更時自動推播 LINE 通知</span>
                                    </div>
                                </div>
                            </setting>
                            <setting string="管理員">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="cfg_admin_line_user_id" string="管理員 LINE UID"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="cfg_admin_line_user_id" class="col-lg-6"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                    </div>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
