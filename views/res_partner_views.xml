<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/res_partner_views.xml -->
<!-- 擴充 res.partner：LINE 整合分頁 -->
<odoo>

    <!-- 擴充 Partner Form：加入 LINE 分頁 -->
    <record id="res_partner_view_form_line" model="ir.ui.view">
        <field name="name">res.partner.form.line</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- 在按鈕區域加入 LINE 狀態按鈕 -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="action" icon="fa-commenting"
                        name="%(woow_line_base.action_line_user)d"
                        context="{'search_default_partner_id': id}">
                    <field name="has_line_bound" widget="boolean" string="LINE"/>
                </button>
            </xpath>

            <!-- 在 internal_notes 頁籤後加入 LINE 分頁 -->
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="LINE 整合" name="line_integration"
                      groups="woow_line_base.group_line_user">
                    <group string="LINE 帳號">
                        <field name="line_user_ids" nolabel="1">
                            <list create="0" edit="0">
                                <field name="display_name"/>
                                <field name="line_user_id"/>
                                <field name="is_follower"/>
                                <field name="notification_enabled" widget="boolean_toggle"/>
                                <field name="last_login"/>
                                <field name="push_count"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- 擴充 Partner List：加入 LINE 綁定欄位 -->
    <record id="res_partner_view_tree_line" model="ir.ui.view">
        <field name="name">res.partner.tree.line</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="has_line_bound" string="LINE" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- 擴充 Partner Search：加入 LINE 篩選 -->
    <record id="res_partner_view_search_line" model="ir.ui.view">
        <field name="name">res.partner.search.line</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter name="line_bound" string="已綁定 LINE"
                        domain="[('has_line_bound', '=', True)]"/>
                <filter name="line_not_bound" string="未綁定 LINE"
                        domain="[('has_line_bound', '=', False)]"/>
            </xpath>
        </field>
    </record>

</odoo>
