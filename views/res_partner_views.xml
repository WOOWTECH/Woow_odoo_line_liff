<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/res_partner_views.xml -->
<!-- res.partner form 加身體狀況欄位 (Mark Studio 專用) -->
<!-- LINE 分頁（line_user_ids, has_line_bound）已移至 woow_line_base -->
<odoo>

    <!-- 擴充 Partner Form：加入身體狀況分頁 -->
    <record id="res_partner_view_form_line" model="ir.ui.view">
        <field name="name">res.partner.form.markstudio</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- 在 internal_notes 頁籤後加入身體狀況分頁 -->
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="身體狀況" name="body_condition"
                      groups="woow_line_base.group_line_user">
                    <group>
                        <group string="偏好設定">
                            <field name="preferred_time_slot"/>
                        </group>
                        <group string="到店統計">
                            <field name="last_visit_date"/>
                            <field name="visit_count"/>
                        </group>
                    </group>
                    <group string="身體狀況備註">
                        <field name="body_condition_notes" nolabel="1"
                               placeholder="記錄客戶的身體狀況，例如：肩頸痠痛、腰痛、過敏史等..."/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
