<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/line_news_views.xml -->
<!-- 最新消息後台管理視圖 -->
<odoo>

    <!-- Tree View -->
    <record id="line_news_view_tree" model="ir.ui.view">
        <field name="name">line.news.tree</field>
        <field name="model">line.news</field>
        <field name="arch" type="xml">
            <tree string="最新消息" default_order="published_date desc">
                <field name="title"/>
                <field name="published_date"/>
                <field name="is_published" widget="boolean_toggle"/>
                <field name="line_push_sent"/>
                <field name="author_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="line_news_view_form" model="ir.ui.view">
        <field name="name">line.news.form</field>
        <field name="model">line.news</field>
        <field name="arch" type="xml">
            <form string="最新消息">
                <header>
                    <button name="action_publish" string="發佈" type="object"
                            class="oe_highlight"
                            invisible="is_published"/>
                    <button name="action_unpublish" string="取消發佈" type="object"
                            invisible="not is_published"/>
                    <button name="action_push_to_line" string="推播到 LINE" type="object"
                            class="oe_highlight"
                            invisible="not is_published or line_push_sent"
                            groups="woow_line_base.group_line_manager"
                            confirm="確定要推播給所有 LINE 好友嗎？"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="文章標題"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="summary" placeholder="簡短摘要（在列表頁顯示）"/>
                            <field name="published_date"/>
                            <field name="author_id"/>
                        </group>
                        <group>
                            <field name="image" widget="image" options="{'size': [256, 256]}"/>
                            <field name="image_url"/>
                            <field name="is_published"/>
                            <field name="line_push_sent" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="內容">
                            <field name="body"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="line_news_view_search" model="ir.ui.view">
        <field name="name">line.news.search</field>
        <field name="model">line.news</field>
        <field name="arch" type="xml">
            <search string="最新消息">
                <field name="title"/>
                <field name="author_id"/>
                <filter name="published" string="已發佈" domain="[('is_published', '=', True)]"/>
                <filter name="draft" string="草稿" domain="[('is_published', '=', False)]"/>
                <filter name="pushed" string="已推播" domain="[('line_push_sent', '=', True)]"/>
                <group expand="0" string="分組">
                    <filter string="發佈日期" name="group_date" context="{'group_by': 'published_date'}"/>
                    <filter string="作者" name="group_author" context="{'group_by': 'author_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_line_news" model="ir.actions.act_window">
        <field name="name">最新消息</field>
        <field name="res_model">line.news</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_published': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立第一篇最新消息
            </p>
            <p>在這裡撰寫文章，發佈後會顯示在 LIFF 最新消息頁面。</p>
        </field>
    </record>

</odoo>
