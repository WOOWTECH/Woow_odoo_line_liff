<?xml version="1.0" encoding="utf-8"?>
<!-- woow_odoo_line_liff/views/line_news_views.xml -->
<!-- 最新消息後台管理視圖 -->
<odoo>

    <!-- Tree View -->
    <record id="line_news_view_tree" model="ir.ui.view">
        <field name="name">line.news.tree</field>
        <field name="model">line.news</field>
        <field name="arch" type="xml">
            <list string="最新消息" default_order="published_date desc"
                  decoration-muted="state == 'draft'">
                <field name="title"/>
                <field name="published_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'published'"
                       decoration-info="state == 'draft'"/>
                <field name="push_method" string="推播方式"/>
                <field name="line_push_count" string="推播次數"/>
                <field name="line_last_push" string="最近推播"/>
                <field name="author_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="line_news_view_form" model="ir.ui.view">
        <field name="name">line.news.form</field>
        <field name="model">line.news</field>
        <field name="arch" type="xml">
            <form string="最新消息">
                <header>
                    <button name="action_publish" string="確認發佈" type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_push_to_line" string="推播到 LINE" type="object"
                            class="oe_highlight"
                            invisible="state != 'published'"
                            groups="woow_line_base.group_line_manager"
                            confirm="確定要推播嗎？"/>
                    <button name="action_draft" string="退回草稿" type="object"
                            invisible="state != 'published'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="文章標題"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="summary" placeholder="簡短摘要（在列表頁顯示）"/>
                            <field name="published_date"/>
                            <field name="author_id"/>
                        </group>
                        <group>
                            <field name="image" widget="image" options="{'size': [256, 256]}"/>
                            <field name="card_url" widget="url"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="內容" name="page_content">
                            <field name="body"/>
                        </page>
                        <page string="推播設定" name="page_push">
                            <group>
                                <group string="推播方式">
                                    <field name="push_method" widget="radio"/>
                                </group>
                                <group string="推播對象" invisible="push_method in ('broadcast', 'narrowcast')">
                                    <field name="push_target_ids" widget="many2many_tags"
                                           placeholder="留空 = 所有追蹤中的用戶"/>
                                </group>
                                <group string="分眾標籤" invisible="push_method != 'narrowcast'">
                                    <field name="push_audience_tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"
                                           placeholder="選擇分眾群組"/>
                                </group>
                            </group>
                            <group string="配額 / 推播紀錄">
                                <group>
                                    <field name="config_id" string="LINE 官方帳號"/>
                                    <field name="quota_display" readonly="1" string="本月配額"/>
                                </group>
                                <group>
                                    <field name="line_push_count" readonly="1"/>
                                    <field name="line_last_push" readonly="1"/>
                                    <field name="line_last_push_method" readonly="1"/>
                                    <field name="line_last_push_sent" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="line_news_view_search" model="ir.ui.view">
        <field name="name">line.news.search</field>
        <field name="model">line.news</field>
        <field name="arch" type="xml">
            <search string="最新消息">
                <field name="title"/>
                <field name="author_id"/>
                <filter name="published" string="已發佈"
                        domain="[('state', '=', 'published')]"/>
                <filter name="draft" string="草稿"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="pushed" string="已推播"
                        domain="[('line_push_count', '>', 0)]"/>
                <group expand="0" string="分組">
                    <filter string="狀態" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="推播方式" name="group_method" context="{'group_by': 'push_method'}"/>
                    <filter string="發佈日期" name="group_date" context="{'group_by': 'published_date'}"/>
                    <filter string="作者" name="group_author" context="{'group_by': 'author_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_line_news" model="ir.actions.act_window">
        <field name="name">最新消息</field>
        <field name="res_model">line.news</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立第一篇最新消息
            </p>
            <p>在這裡撰寫文章，確認發佈後會顯示在 LIFF 最新消息頁面，也可推播到 LINE。</p>
        </field>
    </record>

</odoo>
