<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/menus.xml -->
<!-- LINE Bridge 後台選單 -->
<odoo>

    <!-- 頂層選單 -->
    <menuitem id="menu_line_bridge_root"
              name="LINE Bridge"
              sequence="90"
              web_icon="woow_line_bridge,static/description/icon.png"
              groups="woow_line_base.group_line_user"/>

    <!-- LINE 設定檔（POS 風格多實體） -->
    <menuitem id="menu_line_liff_config"
              name="LINE 設定檔"
              parent="menu_line_bridge_root"
              action="action_line_liff_config"
              sequence="5"
              groups="woow_line_base.group_line_manager"/>

    <!-- LINE 用戶管理（action 在 woow_line_base） -->
    <menuitem id="menu_line_users"
              name="LINE 用戶"
              parent="menu_line_bridge_root"
              action="woow_line_base.action_line_user"
              sequence="10"/>

    <!-- 最新消息 -->
    <menuitem id="menu_line_news"
              name="最新消息"
              parent="menu_line_bridge_root"
              action="action_line_news"
              sequence="15"/>

    <!-- 關鍵字自動回覆 -->
    <menuitem id="menu_line_auto_reply"
              name="關鍵字自動回覆"
              parent="menu_line_bridge_root"
              action="action_line_auto_reply"
              sequence="16"
              groups="woow_line_base.group_line_manager"/>

    <!-- Rich Menu 管理（別名已整合到表單內） -->
    <menuitem id="menu_line_richmenu"
              name="Rich Menu"
              parent="menu_line_bridge_root"
              action="action_line_richmenu"
              sequence="18"
              groups="woow_line_base.group_line_manager"/>

    <!-- 記錄 -->
    <menuitem id="menu_line_logs"
              name="記錄"
              parent="menu_line_bridge_root"
              sequence="20"/>

    <menuitem id="menu_line_event_log"
              name="事件記錄"
              parent="menu_line_logs"
              action="action_line_event_log"
              sequence="10"/>

    <menuitem id="menu_line_push_log"
              name="推播記錄"
              parent="menu_line_logs"
              action="action_line_push_log"
              sequence="20"/>

    <!-- 設定 -->
    <menuitem id="menu_line_config"
              name="設定"
              parent="menu_line_bridge_root"
              action="base.res_config_setting_act_window"
              sequence="99"
              groups="woow_line_base.group_line_manager"/>

</odoo>
