<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/liff_member.xml -->
<!-- 馬克健身會員中心主入口頁（6 宮格功能列表，品牌色） -->
<odoo>

    <template id="liff_member_page" name="LIFF Member Page">
        <t t-call="woow_line_bridge.liff_layout">
            <div class="liff-member" id="liff-member-app">

                <!-- 頂部品牌 Header -->
                <div class="liff-member-header">
                    <div class="liff-member-avatar" id="liff-user-avatar">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                            <circle cx="24" cy="24" r="24" fill="#E0D5C8"/>
                            <circle cx="24" cy="18" r="8" fill="#B8956A"/>
                            <ellipse cx="24" cy="38" rx="14" ry="10" fill="#B8956A"/>
                        </svg>
                    </div>
                    <h1 class="liff-member-shop-name" t-esc="shop_name"/>
                    <p class="liff-member-greeting" id="liff-user-greeting">歡迎光臨</p>
                </div>

                <!-- 錯誤訊息 -->
                <t t-if="error">
                    <div class="liff-member-error">
                        <p t-if="error == 'no_token'">登入失敗：缺少驗證資訊</p>
                        <p t-if="error == 'invalid_token'">登入失敗：驗證過期，請重新開啟</p>
                        <p t-if="error == 'login_failed'">登入失敗：請稍後再試</p>
                        <p t-if="error == 'user_creation_failed'">帳號建立失敗，請聯繫客服</p>
                    </div>
                </t>

                <!-- 6 宮格功能列表 -->
                <div class="liff-member-grid">

                    <!-- 立即預約 -->
                    <a class="liff-member-card" id="btn-book" href="#">
                        <div class="liff-member-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                                <line x1="12" y1="14" x2="12" y2="18"/>
                                <line x1="10" y1="16" x2="14" y2="16"/>
                            </svg>
                        </div>
                        <span class="liff-member-card-label">立即預約</span>
                    </a>

                    <!-- 我的預約 -->
                    <a class="liff-member-card" id="btn-my-bookings" href="#">
                        <div class="liff-member-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="9" y1="13" x2="15" y2="13"/>
                                <line x1="9" y1="17" x2="15" y2="17"/>
                            </svg>
                        </div>
                        <span class="liff-member-card-label">我的預約</span>
                    </a>

                    <!-- 個人資料 -->
                    <a class="liff-member-card" id="btn-profile" href="#">
                        <div class="liff-member-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <span class="liff-member-card-label">個人資料</span>
                    </a>

                    <!-- 最新消息 -->
                    <a class="liff-member-card" id="btn-news" href="/liff/news">
                        <div class="liff-member-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="2">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                            </svg>
                        </div>
                        <span class="liff-member-card-label">最新消息</span>
                    </a>

                    <!-- 店家位置 -->
                    <a class="liff-member-card" id="btn-locations" href="/liff/locations">
                        <div class="liff-member-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                <circle cx="12" cy="10" r="3"/>
                            </svg>
                        </div>
                        <span class="liff-member-card-label">店家位置</span>
                    </a>

                    <!-- 聯絡我們 -->
                    <a class="liff-member-card" id="btn-contact" href="#">
                        <div class="liff-member-card-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <span class="liff-member-card-label">聯絡我們</span>
                    </a>

                </div>

                <!-- 底部版權 -->
                <div class="liff-member-footer">
                    <p>Powered by WOOWTECH</p>
                </div>

            </div>

            <!-- 引入 LIFF SDK 與 member 頁面 JS -->
            <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
            <script>
                // LIFF ID 傳給前端 JS
                window.__LIFF_ID__ = '<t t-esc="liff_id"/>';
            </script>
            <script src="/woow_line_bridge/static/src/js/liff_member.js?v=2"></script>
        </t>
    </template>

</odoo>
