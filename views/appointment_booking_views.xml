<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/appointment_booking_views.xml -->
<!-- 擴充 appointment.booking 後台視圖：加 LINE 通知相關欄位與按鈕 -->
<odoo>

    <!-- 擴充 Booking Form：加入 LINE 通知區塊 -->
    <record id="appointment_booking_view_form_line" model="ir.ui.view">
        <field name="name">appointment.booking.form.line</field>
        <field name="model">appointment.booking</field>
        <field name="inherit_id" ref="reservation_module.view_appointment_booking_form"/>
        <field name="arch" type="xml">

            <!-- 在 header 加入重發 LINE 通知按鈕 -->
            <xpath expr="//header" position="inside">
                <button name="action_resend_line_notification" type="object"
                        string="重發 LINE 通知" class="btn-secondary"
                        groups="woow_line_bridge.group_line_manager"
                        invisible="state != 'confirmed'"/>
            </xpath>

            <!-- 在表單底部加入 LINE 通知狀態 -->
            <xpath expr="//sheet" position="inside">
                <group string="LINE 通知狀態" groups="woow_line_bridge.group_line_user">
                    <group>
                        <field name="line_notification_sent"/>
                        <field name="line_reminder_24h_sent"/>
                        <field name="line_reminder_2h_sent"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

    <!-- 擴充 Booking List：加入 LINE 通知狀態 -->
    <record id="appointment_booking_view_tree_line" model="ir.ui.view">
        <field name="name">appointment.booking.tree.line</field>
        <field name="model">appointment.booking</field>
        <field name="inherit_id" ref="reservation_module.view_appointment_booking_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="line_notification_sent" string="LINE" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
