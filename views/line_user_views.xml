<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/views/line_user_views.xml -->
<!-- 繼承 woow_line_base 的 LINE 用戶視圖，加入 bridge 功能 -->
<odoo>

    <!-- 擴充 Tree View：加入 Rich Menu 欄位 -->
    <record id="line_user_view_tree_bridge" model="ir.ui.view">
        <field name="name">line.user.tree.bridge</field>
        <field name="model">line.user</field>
        <field name="inherit_id" ref="woow_line_base.line_user_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='event_count']" position="after">
                <field name="current_richmenu_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- 擴充 Form View：加入測試推播按鈕、smart buttons、Rich Menu -->
    <record id="line_user_view_form_bridge" model="ir.ui.view">
        <field name="name">line.user.form.bridge</field>
        <field name="model">line.user</field>
        <field name="inherit_id" ref="woow_line_base.line_user_view_form"/>
        <field name="arch" type="xml">
            <!-- 在 header 增加測試推播按鈕 -->
            <xpath expr="//header" position="inside">
                <button name="push_text" type="object" string="發送測試訊息"
                        class="btn-primary" groups="woow_line_base.group_line_manager"
                        context="{'default_text': '這是測試訊息'}"/>
            </xpath>

            <!-- 在 sheet 開頭加入 button_box（smart buttons） -->
            <xpath expr="//sheet/div[@class='oe_title']" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_partner"
                            type="object" class="oe_stat_button" icon="fa-user"
                            invisible="not partner_id">
                        <div class="o_stat_info">
                            <span class="o_stat_text">聯絡人</span>
                        </div>
                    </button>
                    <button name="%(woow_line_bridge.action_line_event_log)d"
                            type="action" class="oe_stat_button" icon="fa-list"
                            context="{'search_default_line_user_id': id}">
                        <field name="event_count" widget="statinfo" string="事件"/>
                    </button>
                    <button name="%(woow_line_bridge.action_line_push_log)d"
                            type="action" class="oe_stat_button" icon="fa-paper-plane"
                            context="{'search_default_line_user_id': id}">
                        <field name="push_count" widget="statinfo" string="推播"/>
                    </button>
                </div>
            </xpath>

            <!-- 在設定 tab 加入 Rich Menu 欄位 -->
            <xpath expr="//page[@name='settings']/group" position="inside">
                <group>
                    <field name="current_richmenu_id"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
