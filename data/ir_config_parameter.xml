<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/data/ir_config_parameter.xml -->
<!-- LIFF + 店家資訊系統參數預設值 -->
<!-- LINE Login / Messaging API 金鑰已移至 woow_line_base -->
<odoo>
    <data noupdate="1">

        <!-- LIFF ID -->
        <record id="config_liff_id_member" model="ir.config_parameter">
            <field name="key">woow_line_liff.liff_id_member</field>
            <field name="value"></field>
        </record>
        <record id="config_liff_id_news" model="ir.config_parameter">
            <field name="key">woow_line_liff.liff_id_news</field>
            <field name="value"></field>
        </record>
        <record id="config_liff_id_locations" model="ir.config_parameter">
            <field name="key">woow_line_liff.liff_id_locations</field>
            <field name="value"></field>
        </record>

        <!-- 店家資訊 -->
        <record id="config_shop_name" model="ir.config_parameter">
            <field name="key">woow_line_liff.shop_name</field>
            <field name="value">Mark Studio 馬克健身</field>
        </record>
        <record id="config_shop_address" model="ir.config_parameter">
            <field name="key">woow_line_liff.shop_address</field>
            <field name="value"></field>
        </record>
        <record id="config_shop_phone" model="ir.config_parameter">
            <field name="key">woow_line_liff.shop_phone</field>
            <field name="value"></field>
        </record>
        <record id="config_shop_latitude" model="ir.config_parameter">
            <field name="key">woow_line_liff.shop_latitude</field>
            <field name="value"></field>
        </record>
        <record id="config_shop_longitude" model="ir.config_parameter">
            <field name="key">woow_line_liff.shop_longitude</field>
            <field name="value"></field>
        </record>
        <record id="config_shop_opening_hours" model="ir.config_parameter">
            <field name="key">woow_line_liff.shop_opening_hours</field>
            <field name="value"></field>
        </record>

    </data>
</odoo>
