<?xml version="1.0" encoding="utf-8"?>
<!-- woow_line_bridge/data/ir_cron.xml -->
<!-- 排程任務：預約提醒 -->
<odoo>
    <data noupdate="1">

        <!-- 預約前 24 小時提醒（每小時檢查一次） -->
        <record id="ir_cron_booking_reminder_24h" model="ir.cron">
            <field name="name">LINE: 預約前 24 小時提醒</field>
            <field name="model_id" ref="model_appointment_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_line_reminder_24h()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- 預約前 2 小時提醒（每 30 分鐘檢查一次） -->
        <record id="ir_cron_booking_reminder_2h" model="ir.cron">
            <field name="name">LINE: 預約前 2 小時提醒</field>
            <field name="model_id" ref="model_appointment_booking"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_line_reminder_2h()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
